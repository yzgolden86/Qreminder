{
  "name": "qreminder",
  "private": true,
  "license": "MIT",
  "version": "0.0.0",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "pnpm --filter @qreminder/client dev",
    "build:client": "pnpm --filter @qreminder/client build",
    "check:file-lines": "node scripts/check-file-lines.mjs",
    "lint": "pnpm --filter @qreminder/client lint",
    "test": "pnpm --filter @qreminder/client test",
    "test:run": "pnpm --filter @qreminder/client test:run",
    "test:e2e": "playwright test",
    "test:all": "pnpm check:file-lines && pnpm --filter @qreminder/client test:run && pnpm --filter @qreminder/client typecheck && pnpm --filter @qreminder/client typecheck:all && pnpm test:e2e",
    "typecheck": "pnpm --filter @qreminder/client typecheck",
    "update:thesvg-index": "node scripts/update-thesvg-index.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
