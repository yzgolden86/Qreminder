# Qreminder Node 自托管部署配置
#
# 复制为 .env 后按需填写。BETTER_AUTH_SECRET / APP_URL 必填，其余可空。

# 必填 ----------------------------------------------------------------------

# 32+ 位随机串。可在本地用 `openssl rand -hex 32` 生成。
BETTER_AUTH_SECRET=

# 对外完整 URL（带 https，不带尾斜杠）。本地可用 http://localhost:3000。
APP_URL=http://localhost:3000

# 可选 ----------------------------------------------------------------------

# 宿主机映射端口。容器内固定监听 3000。
PORT=3000

# Better Auth cookie 域允许列表，多个用逗号分隔。留空时退化成只接受 APP_URL 的 origin。
TRUSTED_ORIGINS=

# 第一次注册第一个 admin 时设为 true，注册完改回 false 并 docker compose restart。
SIGNUP_ENABLED=false

# 注册邮箱白名单（仅 SIGNUP_ENABLED=true 时生效）。多个邮箱用逗号分隔，支持 *@example.com 通配。
SIGNUP_ALLOWLIST=

# SMTP（配置后启用密码找回 + 续费提醒邮件）。任一项空则邮件发送被禁用。
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Cron 调度。默认每分钟扫一次，按用户的本地时区判断是否真发。
NOTIFICATION_SCHEDULER_ENABLED=true
NOTIFICATION_SCHEDULER_CRON=* * * * *
